# Copy to deploy/.env and fill in. Every appliance gets a UNIQUE secret.
VIBE_PRINT_SECRET=change-me-to-a-long-random-string

# Cloudflare profile only:
# TUNNEL_TOKEN=eyJh...

# When fronted by a proxy, list its peer so real client IPs are trusted:
# VIBE_PRINT_TRUSTED_PROXIES=["127.0.0.1","172.16.0.0/12"]
